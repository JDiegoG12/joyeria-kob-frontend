# ─── SPA fallback ──────────────────────────────────────────────────────
# Sin esto, /catalogo, /admin/joyas, etc. dan 404 porque Apache busca un
# archivo físico que no existe. Reescribimos a /index.html y dejamos que
# React Router decida la vista en el cliente.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Si la URL pide un archivo real (ej. /assets/index-abc.js, /favicon.svg),
  # se sirve tal cual. Esta condición es CRÍTICA — sin ella reescribirías
  # incluso las peticiones a tus assets y la página queda en blanco.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Todo lo demás → index.html
  RewriteRule . /index.html [L]
</IfModule>

# ─── Caché de assets con hash ──────────────────────────────────────────
# Vite genera nombres con hash de contenido (ej. index-Bx9aQ12.js). Si el
# contenido cambia, el hash cambia → el navegador descarga el nuevo. Por
# eso podemos cachearlos un año sin riesgo de servir versión vieja.
<IfModule mod_expires.c>
  ExpiresActive On

  <FilesMatch "\.(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|gif|webp|ico)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  # index.html NO se cachea — siempre tiene que llegar fresco para que los
  # hashes de los assets que referencia sean los del último deploy.
  <FilesMatch "index\.html$">
    ExpiresDefault "access plus 0 seconds"
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ─── Compresión gzip ───────────────────────────────────────────────────
# Reduce el tamaño de transferencia de JS/CSS/HTML ~70%. Hostinger soporta
# mod_deflate por defecto.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
